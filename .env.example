# SvelteKit → Axum proxy (server-side only)
PE_API_ORIGIN=http://127.0.0.1:8080

# Axum API bind address
PE_API_BIND_HOST=127.0.0.1
PE_API_BIND_PORT=8080

# Database (Axum). SQLite default creates apps/api/data/pe.db when run from apps/api.
# Optional: PostgreSQL (e.g. after `docker compose up -d postgres`):
# PE_DATABASE_URL=postgres://pe:pe@127.0.0.1:5432/prospect
PE_DATABASE_URL=sqlite:data/pe.db

# JWT signing secret — required in release builds (min 32 characters). Set in production.
# PE_JWT_SECRET=

# Comma-separated browser origins allowed for CORS (e.g. https://app.example.com).
# Required in release API builds. Omit in local debug only (permissive CORS).
# PE_CORS_ALLOW_ORIGINS=https://127.0.0.1:5173,http://localhost:5173
