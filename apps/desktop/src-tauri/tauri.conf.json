{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "ProspectEngine",
	"version": "0.1.0",
	"identifier": "com.prospectengine.desktop",
	"build": {
		"frontendDist": "../../web/build",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "cd ../.. && pnpm --filter @pe/web dev",
		"beforeBuildCommand": "cd ../.. && pnpm --filter @pe/web build"
	},
	"app": {
		"windows": [
			{
				"title": "ProspectEngine",
				"width": 800,
				"height": 600,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
